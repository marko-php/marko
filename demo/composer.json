{
    "name": "marko/demo",
    "description": "Demo application for Marko Framework",
    "type": "project",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "marko/core": "*",
        "marko/routing": "*",
        "marko/blog": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../packages/core"
        },
        {
            "type": "path",
            "url": "../packages/routing"
        },
        {
            "type": "path",
            "url": "../packages/blog"
        }
    ],
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
