{
    "name": "marko/queue-rabbitmq",
    "description": "RabbitMQ queue driver for Marko Framework",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/queue": "@dev",
        "php-amqplib/php-amqplib": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Queue\\Rabbitmq\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Queue\\Rabbitmq\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
