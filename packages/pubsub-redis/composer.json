{
    "name": "marko/pubsub-redis",
    "description": "Redis pub/sub driver for Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../pubsub"
        }
    ],
    "require": {
        "php": "^8.5",
        "amphp/redis": "^2.0",
        "marko/core": "@dev",
        "marko/config": "@dev",
        "marko/pubsub": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\PubSub\\Redis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\PubSub\\Redis\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
