{
    "name": "marko/view",
    "description": "Marko Framework View - Templating interfaces and contracts",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/routing": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../config"
        }
    ],
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\View\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\View\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
