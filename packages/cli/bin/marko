#!/usr/bin/env php
<?php

declare(strict_types=1);

// Autoloader for CLI package
$autoloaders = [
    __DIR__ . '/../vendor/autoload.php',        // CLI package has own vendor (installed globally)
    __DIR__ . '/../../../autoload.php',          // Installed as dependency in project
    __DIR__ . '/../../../vendor/autoload.php',   // Monorepo development (packages/cli/bin -> root/vendor)
];

foreach ($autoloaders as $autoloader) {
    if (file_exists($autoloader)) {
        require $autoloader;
        break;
    }
}

use Marko\Cli\CliKernel;
use Marko\Cli\ProjectFinder;

try {
    $kernel = new CliKernel(
        projectFinder: new ProjectFinder(),
    );
    $exitCode = $kernel->run($argv);
    exit($exitCode);
} catch (Throwable $e) {
    fwrite(STDERR, "Error: " . $e->getMessage() . PHP_EOL);
    exit(1);
}
