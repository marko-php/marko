{
    "name": "marko/tailwindcss",
    "description": "Marko Framework Tailwind CSS integration",
    "license": "MIT",
    "type": "marko-module",
    "require": {
        "php": "^8.5",
        "marko/config": "self.version",
        "marko/core": "self.version",
        "marko/vite": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\TailwindCss\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\TailwindCss\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
