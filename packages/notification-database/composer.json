{
    "name": "marko/notification-database",
    "description": "Database-backed notification storage for the Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/notification": "self.version",
        "marko/database": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Notification\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Notification\\Database\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
