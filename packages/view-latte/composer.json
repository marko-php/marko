{
    "name": "marko/view-latte",
    "description": "Latte templating driver for Marko Framework View",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/view": "@dev",
        "latte/latte": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\View\\Latte\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\View\\Latte\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
