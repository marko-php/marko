{
    "name": "marko/authorization",
    "description": "Policy-based authorization with Gates and Policies for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "repositories": [
        {"type": "path", "url": "../core"},
        {"type": "path", "url": "../authentication"},
        {"type": "path", "url": "../routing"},
        {"type": "path", "url": "../config"}
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/authentication": "@dev",
        "marko/routing": "@dev",
        "marko/config": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Authorization\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Authorization\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
