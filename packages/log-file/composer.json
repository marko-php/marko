{
    "name": "marko/log-file",
    "description": "File-based logging driver for Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../log"
        }
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/config": "@dev",
        "marko/log": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Log\\File\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Log\\File\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
