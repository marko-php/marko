{
    "name": "marko/pubsub-pgsql",
    "description": "PostgreSQL pub/sub driver for Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "require": {
        "php": "^8.5",
        "amphp/postgres": "^2",
        "marko/core": "self.version",
        "marko/config": "self.version",
        "marko/pubsub": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\PubSub\\PgSql\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\PubSub\\PgSql\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
