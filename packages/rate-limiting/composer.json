{
    "name": "marko/rate-limiting",
    "description": "Rate limiting for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/config": "@dev",
        "marko/cache": "@dev",
        "marko/routing": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\RateLimiting\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\RateLimiting\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
