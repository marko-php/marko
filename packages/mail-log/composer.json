{
    "name": "marko/mail-log",
    "description": "Log driver for Marko Framework Mail",
    "license": "MIT",
    "type": "marko-module",
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../mail"
        },
        {
            "type": "path",
            "url": "../log"
        }
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/mail": "@dev",
        "marko/log": "@dev"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Mail\\Log\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Mail\\Log\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
