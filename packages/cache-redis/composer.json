{
    "name": "marko/cache-redis",
    "description": "Redis cache driver for Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../cache"
        }
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/config": "@dev",
        "marko/cache": "@dev",
        "predis/predis": "^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "marko/testing": "*"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Cache\\Redis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Cache\\Redis\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
