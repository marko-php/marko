{
    "name": "marko/marko",
    "description": "Marko Framework - Enterprise-grade extensibility with modern developer experience",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.92",
        "pestphp/pest": "^4.3",
        "rector/rector": "^2.3",
        "slevomat/coding-standard": "^8.26",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Blog\\": "packages/blog/src/",
            "Marko\\Cli\\": "packages/cli/src/",
            "Marko\\Core\\": "packages/core/src/",
            "Marko\\Errors\\": "packages/errors/src/",
            "Marko\\ErrorsSimple\\": "packages/errors-simple/src/",
            "Marko\\Routing\\": "packages/routing/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Blog\\Tests\\": "packages/blog/tests/",
            "Marko\\Cli\\Tests\\": "packages/cli/tests/",
            "Marko\\Core\\Tests\\": "packages/core/tests/",
            "Marko\\Errors\\Tests\\": "packages/errors/tests/",
            "Marko\\ErrorsSimple\\Tests\\": "packages/errors-simple/tests/",
            "Marko\\Routing\\Tests\\": "packages/routing/tests/"
        }
    },
    "scripts": {
        "test": "pest -c phpunit.xml --test-directory=packages/core/tests",
        "cs:check": "phpcs --standard=phpcs.xml",
        "cs:fix": [
            "php-cs-fixer fix --config=.php-cs-fixer.php",
            "phpcbf --standard=phpcs.xml || true"
        ],
        "rector": "rector process"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
