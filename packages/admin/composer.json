{
    "name": "marko/admin",
    "description": "Admin contracts for Marko Framework",
    "type": "library",
    "license": "MIT",
    "repositories": [
        {"type": "path", "url": "../core"},
        {"type": "path", "url": "../routing"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../testing"}
    ],
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/routing": "@dev",
        "marko/config": "@dev"
    },
    "require-dev": {
        "marko/testing": "@dev",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Admin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Admin\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
