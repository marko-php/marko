{
    "name": "marko/database-pgsql",
    "description": "PostgreSQL driver for Marko Framework Database Layer",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/database": "@dev",
        "ext-pdo": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Database\\PgSql\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Database\\PgSql\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
