{
    "name": "marko/marko",
    "description": "Marko Framework - Enterprise-grade extensibility with modern developer experience",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-pdo": "*",
        "ext-fileinfo": "*"
    },
    "require-dev": {
        "aws/aws-sdk-php": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.92",
        "guzzlehttp/guzzle": "^7.0",
        "latte/latte": "^3.0",
        "pestphp/pest": "^4.3",
        "php-amqplib/php-amqplib": "^3.0",
        "predis/predis": "^2.0",
        "rector/rector": "^2.3",
        "slevomat/coding-standard": "^8.26",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "files": [
            "packages/env/src/functions.php"
        ],
        "psr-4": {
            "Marko\\Blog\\": "packages/blog/src/",
            "Marko\\Cache\\": "packages/cache/src/",
            "Marko\\Cache\\File\\": "packages/cache-file/src/",
            "Marko\\Cache\\Memory\\": "packages/cache-array/src/",
            "Marko\\Cache\\Redis\\": "packages/cache-redis/src/",
            "Marko\\Cli\\": "packages/cli/src/",
            "Marko\\Config\\": "packages/config/src/",
            "Marko\\Core\\": "packages/core/src/",
            "Marko\\Database\\": "packages/database/src/",
            "Marko\\Database\\MySql\\": "packages/database-mysql/src/",
            "Marko\\Database\\PgSql\\": "packages/database-pgsql/src/",
            "Marko\\Encryption\\": "packages/encryption/src/",
            "Marko\\Encryption\\OpenSsl\\": "packages/encryption-openssl/src/",
            "Marko\\Env\\": "packages/env/src/",
            "Marko\\Errors\\": "packages/errors/src/",
            "Marko\\ErrorsAdvanced\\": "packages/errors-advanced/src/",
            "Marko\\ErrorsSimple\\": "packages/errors-simple/src/",
            "Marko\\Filesystem\\": "packages/filesystem/src/",
            "Marko\\Filesystem\\Local\\": "packages/filesystem-local/src/",
            "Marko\\Filesystem\\S3\\": "packages/filesystem-s3/src/",
            "Marko\\Hashing\\": "packages/hashing/src/",
            "Marko\\Http\\": "packages/http/src/",
            "Marko\\Http\\Guzzle\\": "packages/http-guzzle/src/",
            "Marko\\Log\\": "packages/log/src/",
            "Marko\\Log\\File\\": "packages/log-file/src/",
            "Marko\\Mail\\": "packages/mail/src/",
            "Marko\\Mail\\Log\\": "packages/mail-log/src/",
            "Marko\\Mail\\Smtp\\": "packages/mail-smtp/src/",
            "Marko\\Routing\\": "packages/routing/src/",
            "Marko\\Session\\": "packages/session/src/",
            "Marko\\Session\\Database\\": "packages/session-database/src/",
            "Marko\\Session\\File\\": "packages/session-file/src/",
            "Marko\\Validation\\": "packages/validation/src/",
            "Marko\\Authentication\\": "packages/authentication/src/",
            "Marko\\Queue\\": "packages/queue/src/",
            "Marko\\Queue\\Sync\\": "packages/queue-sync/src/",
            "Marko\\Queue\\Database\\": "packages/queue-database/src/",
            "Marko\\Queue\\Rabbitmq\\": "packages/queue-rabbitmq/src/",
            "Marko\\RateLimiting\\": "packages/rate-limiting/src/",
            "Marko\\Scheduler\\": "packages/scheduler/src/",
            "Marko\\View\\": "packages/view/src/",
            "Marko\\View\\Latte\\": "packages/view-latte/src/",
            "Marko\\Admin\\": "packages/admin/src/",
            "Marko\\AdminAuth\\": "packages/admin-auth/src/",
            "Marko\\AdminApi\\": "packages/admin-api/src/",
            "Marko\\AdminPanel\\": "packages/admin-panel/src/",
            "Marko\\Authorization\\": "packages/authorization/src/",
            "Marko\\Translation\\": "packages/translation/src/",
            "Marko\\Translation\\File\\": "packages/translation-file/src/",
            "Marko\\Notification\\": "packages/notification/src/",
            "Marko\\Notification\\Database\\": "packages/notification-database/src/",
            "Marko\\Pagination\\": "packages/pagination/src/",
            "Marko\\Security\\": "packages/security/src/",
            "Marko\\Testing\\": "packages/testing/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Admin\\Tests\\": "packages/admin/tests/",
            "Marko\\AdminAuth\\Tests\\": "packages/admin-auth/tests/",
            "Marko\\AdminApi\\Tests\\": "packages/admin-api/tests/",
            "Marko\\AdminPanel\\Tests\\": "packages/admin-panel/tests/",
            "Marko\\Authorization\\Tests\\": "packages/authorization/tests/",
            "Marko\\Blog\\Tests\\": "packages/blog/tests/",
            "Marko\\Cache\\Tests\\": "packages/cache/tests/",
            "Marko\\Cache\\File\\Tests\\": "packages/cache-file/tests/",
            "Marko\\Cache\\Memory\\Tests\\": "packages/cache-array/tests/",
            "Marko\\Cache\\Redis\\Tests\\": "packages/cache-redis/tests/",
            "Marko\\Cli\\Tests\\": "packages/cli/tests/",
            "Marko\\Config\\Tests\\": "packages/config/tests/",
            "Marko\\Core\\Tests\\": "packages/core/tests/",
            "Marko\\Database\\Tests\\": "packages/database/tests/",
            "Marko\\Database\\MySql\\Tests\\": "packages/database-mysql/tests/",
            "Marko\\Database\\PgSql\\Tests\\": "packages/database-pgsql/tests/",
            "Marko\\Encryption\\Tests\\": "packages/encryption/tests/",
            "Marko\\Encryption\\OpenSsl\\Tests\\": "packages/encryption-openssl/tests/",
            "Marko\\Env\\Tests\\": "packages/env/tests/",
            "Marko\\Errors\\Tests\\": "packages/errors/tests/",
            "Marko\\ErrorsAdvanced\\Tests\\": "packages/errors-advanced/tests/",
            "Marko\\ErrorsSimple\\Tests\\": "packages/errors-simple/tests/",
            "Marko\\Filesystem\\Tests\\": "packages/filesystem/tests/",
            "Marko\\Filesystem\\Local\\Tests\\": "packages/filesystem-local/tests/",
            "Marko\\Filesystem\\S3\\Tests\\": "packages/filesystem-s3/tests/",
            "Marko\\Framework\\Tests\\": "packages/framework/tests/",
            "Marko\\Hashing\\Tests\\": "packages/hashing/tests/",
            "Marko\\Http\\Tests\\": "packages/http/tests/",
            "Marko\\Http\\Guzzle\\Tests\\": "packages/http-guzzle/tests/",
            "Marko\\Log\\Tests\\": "packages/log/tests/",
            "Marko\\Log\\File\\Tests\\": "packages/log-file/tests/",
            "Marko\\Mail\\Tests\\": "packages/mail/tests/",
            "Marko\\Mail\\Log\\Tests\\": "packages/mail-log/tests/",
            "Marko\\Mail\\Smtp\\Tests\\": "packages/mail-smtp/tests/",
            "Marko\\Routing\\Tests\\": "packages/routing/tests/",
            "Marko\\Session\\Tests\\": "packages/session/tests/",
            "Marko\\Session\\Database\\Tests\\": "packages/session-database/tests/",
            "Marko\\Session\\File\\Tests\\": "packages/session-file/tests/",
            "Marko\\Validation\\Tests\\": "packages/validation/tests/",
            "Marko\\Authentication\\Tests\\": "packages/authentication/tests/",
            "Marko\\Queue\\Tests\\": "packages/queue/tests/",
            "Marko\\Queue\\Sync\\Tests\\": "packages/queue-sync/tests/",
            "Marko\\Queue\\Database\\Tests\\": "packages/queue-database/tests/",
            "Marko\\Queue\\Rabbitmq\\Tests\\": "packages/queue-rabbitmq/tests/",
            "Marko\\RateLimiting\\Tests\\": "packages/rate-limiting/tests/",
            "Marko\\Scheduler\\Tests\\": "packages/scheduler/tests/",
            "Marko\\View\\Tests\\": "packages/view/tests/",
            "Marko\\Translation\\Tests\\": "packages/translation/tests/",
            "Marko\\Translation\\File\\Tests\\": "packages/translation-file/tests/",
            "Marko\\View\\Latte\\Tests\\": "packages/view-latte/tests/",
            "Marko\\Notification\\Tests\\": "packages/notification/tests/",
            "Marko\\Notification\\Database\\Tests\\": "packages/notification-database/tests/",
            "Marko\\Pagination\\Tests\\": "packages/pagination/tests/",
            "Marko\\Security\\Tests\\": "packages/security/tests/",
            "Marko\\Testing\\Tests\\": "packages/testing/tests/"
        }
    },
    "scripts": {
        "test": "pest -c phpunit.xml --parallel",
        "cs:check": "phpcs --standard=phpcs.xml",
        "cs:fix": [
            "php-cs-fixer fix --config=.php-cs-fixer.php",
            "phpcbf --standard=phpcs.xml || true"
        ],
        "rector": "rector process"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
