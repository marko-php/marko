{
    "name": "marko/lsp",
    "description": "Language Server Protocol implementation for Marko Framework semantics",
    "license": "MIT",
    "type": "marko-module",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/codeindexer": "self.version",
        "marko/cli": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Lsp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Lsp\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
