{
    "name": "marko/database-mysql",
    "description": "MySQL driver for Marko Framework Database Layer",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "^0.1",
        "marko/database": "^0.1",
        "ext-pdo": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Database\\MySql\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Database\\MySql\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
